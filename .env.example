PORT=8888
# Emare AI Configuration
# Copy this file to .env and fill in your values

# API Settings
APP_NAME=Emare AI
APP_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8888
DEBUG=False

# Ollama Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
DEFAULT_MODEL=llama3.1:8b

# Security (optional)
API_KEY=

# CORS (comma-separated)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/emareai.log

# Performance
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=300
